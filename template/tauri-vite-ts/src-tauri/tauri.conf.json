{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "{{PROJECT_TITLE}}",
  "version": "0.0.1",
  "identifier": "{{PROJECT_IDENTIFIER}}",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5200",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "{{PROJECT_TITLE}}",
        "width": 960,
        "height": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
